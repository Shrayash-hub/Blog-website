PORT=8000
NODE_ENV=development

# MongoDB (use MongoDB Atlas free tier connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net
DB_NAME=blogfolio

# CORS - your deployed/local frontend origin
CORS_ORIGIN=http://localhost:5173

# JWT
ACCESS_TOKEN_SECRET=replace_with_a_long_random_string
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string
REFRESH_TOKEN_EXPIRY=10d

# File storage
# LOCAL_UPLOAD_PATH is used until AWS S3 is wired in (see storage.js for the swap point)
LOCAL_UPLOAD_PATH=./public/uploads

# AWS S3 (fill these in once you move file storage to S3)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
